#!/bin/sh
# Maven Wrapper startup script
MAVEN_PROJECTBASEDIR="${MAVEN_BASEDIR:-"$( cd "$(dirname "$0")" && pwd)"}"
WRAPPER_JAR="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.jar"
WRAPPER_PROPERTIES="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.properties"

if [ -f "$WRAPPER_JAR" ]; then
  exec java -jar "$WRAPPER_JAR" "$@"
else
  DOWNLOAD_URL="https://repo.maven.apache.org/maven2/org/apache/maven/wrapper/maven-wrapper/3.3.2/maven-wrapper-3.3.2.jar"
  echo "Downloading maven-wrapper.jar from $DOWNLOAD_URL..."
  if command -v curl > /dev/null; then
    curl -fsSL -o "$WRAPPER_JAR" "$DOWNLOAD_URL" || exit 1
  elif command -v wget > /dev/null; then
    wget -q -O "$WRAPPER_JAR" "$DOWNLOAD_URL" || exit 1
  else
    echo "Error: curl or wget required to download maven-wrapper.jar"
    exit 1
  fi
  exec java -jar "$WRAPPER_JAR" "$@"
fi
